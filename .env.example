# =============================================================================
# percival-osm MCP server — environment reference
# =============================================================================
#
# This file is NOT loaded by the server. The server reads ALL of its
# configuration from process environment variables (see `Settings` in
# `src/percival_osm_mcp/server.py`). The reason for shipping this file is
# purely documentation: it lists every env var the server understands,
# what it does, and what the default is.
#
# Where the values live at runtime
# --------------------------------
# In this repo, the recommended path is the nanobot MCP launcher:
#
#   .nanobot-test/config.json -> tools.mcpServers.percival-osm.env
#
# which gets the actual secret from `.nanobot-test/.env` (gitignored,
# chmod 600) or your shell, via the ${VAR} placeholder expansion handled
# by `scripts/nb`. The server itself never touches a `.env` file.
#
# If you launch the server outside nanobot, just export the variables in
# your shell before starting it. Example:
#
#   export USER_AGENT='percival-osm/0.4.0 (you@example.com)'
#   export FROM_HEADER='you@example.com'
#   export ORS_API_KEY='eyJvcmciOi...'
#   percival-osm-mcp --mode stdio
#
# =============================================================================

# --- Required by Nominatim usage policy --------------------------------------
# Both must be non-empty. Identifiers in the User-Agent allow Nominatim to
# contact you in case of abuse; the From header is part of the policy too.
USER_AGENT=percival-osm/0.4.0 (you@example.com)
FROM_HEADER=you@example.com

# --- Optional: OpenRouteService API key -------------------------------------
# Leave unset to disable routing-enhanced tools (osm_navigate / osm_directions
# fall back to haversine distance, which is less accurate).
ORS_API_KEY=

# --- Optional: endpoint overrides -------------------------------------------
NOMINATIM_URL=https://nominatim.openstreetmap.org/
OVERPASS_TURBO_URL=https://overpass-api.de/api/interpreter
# ORS_INSTANCE=https://api.openrouteservice.org

# --- Runtime behavior --------------------------------------------------------
INSTRUCTION_ORIENTED_INTERPRETATION=true
CAR_ONLY=false
STATUS_INDICATORS=false
OSM_RESPONSE_MODE=compact

# ORS HTTP timeout (seconds). The openrouteservice library defaults to 60s,
# which is too tight for the public instance at peak hours.
ORS_REQUEST_TIMEOUT=90

# --- HTTP auth (required for non-loopback HTTP exposure) ---------------------
MCP_OSM_AUTH_TOKEN=
MCP_OSM_AUTH_TOKEN_ENV=MCP_OSM_AUTH_TOKEN

# --- HTTP client hardening ---------------------------------------------------
OSM_HTTP_TIMEOUT_SECONDS=12
OSM_HTTP_MAX_RETRIES=2
OSM_HTTP_RETRY_BACKOFF_SECONDS=0.6
OSM_HTTP_FOLLOW_REDIRECTS=false
OSM_HTTP_MAX_RESPONSE_BYTES=2000000
OSM_HTTP_MAX_CONCURRENCY=8
OSM_REQUIRE_HTTPS_UPSTREAMS=true
OSM_UPSTREAM_ALLOWED_HOSTS=nominatim.openstreetmap.org,overpass-api.de,api.openrouteservice.org

# --- Rate limiting (Nominatim usage policy: max 1 req/s) ---------------------
OSM_NOMINATIM_RATE_LIMIT_RPS=1.0
OSM_NOMINATIM_RATE_LIMIT_BURST=2

# --- Logging -----------------------------------------------------------------
OSM_LOG_FORMAT=plain
OSM_LOG_LEVEL=INFO

# --- Tool surface ------------------------------------------------------------
OSM_EXPOSE_LEGACY_ALIASES=true

# --- Cache behavior ----------------------------------------------------------
OSM_CACHE_FILE=/tmp/osm-cache.json
OSM_CACHE_TTL_SECONDS=3600
OSM_CACHE_ALLOWED_DIRS=/tmp